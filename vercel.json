{
  "version": 2,
  "builds": [
    { "src": "favicon.svg", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node", "config": { "includeFiles": ["fonts/**", "data/**", "utils/**"] } }
  ],
  "routes": [
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
