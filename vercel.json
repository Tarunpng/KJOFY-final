{
  "version": 2,
  "builds": [
    { "src": "data/images/**", "use": "@vercel/static" },
    { "src": "favicon.svg", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/data/images/(.*)",
      "dest": "/data/images/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
